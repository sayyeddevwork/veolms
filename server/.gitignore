# ============================
# Environment variables — NEVER commit these
# ============================
.env
.env.local
.env.development
.env.production
.env.test
.env*.local
!.env.example

# ============================
# Dependencies
# ============================
node_modules/
**/node_modules/

# ============================
# Build outputs
# ============================
dist/
build/
**/dist/
**/build/
.next/
out/

# ============================
# Prisma
# ============================
# Generated client (regenerated via `prisma generate`, don't commit)
# Migrations SHOULD be committed — do not ignore prisma/migrations/

# ============================
# Logs
# ============================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================
# Testing
# ============================
coverage/
.nyc_output/

# ============================
# TypeScript
# ============================
*.tsbuildinfo

# ============================
# OS files
# ============================
.DS_Store
Thumbs.db

# ============================
# Editor / IDE
